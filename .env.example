# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# Google Cloud API key — sent as x-goog-api-key by the @google/genai SDK.
# Enable the "Generative Language API" in your GCP project, then create a key at:
# https://console.cloud.google.com/apis/credentials
GCP_API_KEY=your-gcp-api-key-here

# Fastly API token — sent as the `fastly-key` header to authenticate with the
# Fastly AI Accelerator (semantic LLM cache). Also used by the Fastly CLI and Terraform.
# Create one at: https://manage.fastly.com/account/personal/tokens
FASTLY_KEY=your-fastly-api-token-here
FASTLY_API_KEY=your-fastly-api-key-here
